# Configuration frontend Vite pour déploiement local / self-hosted
# Copier ce fichier vers .env.local avant de builder l'application.

# URL publique de l'API Supabase accessible DEPUIS LE NAVIGATEUR.
# Déploiement SSH avec proxy nginx de l'app : http://IP_SERVEUR:8080
# Supabase/Kong direct depuis le serveur : http://127.0.0.1:8000
VITE_SUPABASE_URL=http://127.0.0.1:8000

# Clé anon / publishable de l'instance Supabase locale.
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ_REPLACE_WITH_LOCAL_ANON_KEY

# Optionnel en local. Peut rester "local".
VITE_SUPABASE_PROJECT_ID=local

# ============================================================================
# URL PUBLIQUE DE L'APPLICATION (pour génération des liens absolus / QR codes)
# ============================================================================
# Utilisée pour construire les URLs absolues côté front (player, upload, QR).
# - En local : http://localhost:8080
# - En distant : http://home-z.ddns.me:8080  (ou https://votre-domaine.tld)
# Si vide, l'app utilise window.location.origin (runtime).
VITE_PUBLIC_APP_URL=http://home-z.ddns.me:8080

# Sous-chemin de l'application si servie ailleurs qu'à la racine, ex: /app
# Laisser "/" si l'app est servie à la racine du domaine.
VITE_APP_BASE_PATH=/

# Optionnel, uniquement pour scripts/CLI serveur. Ne sera pas exposé au frontend Vite.
DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@127.0.0.1:5432/postgres
